{
  "name": "basetheme",
  "version": "1.0.0",
  "description": "WordPess theme build on Bootstrap 5",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "encore dev",
    "watch": "encore dev --watch",
    "watch-prod": "npm encore prod --watch",
    "prod": "encore prod",
    "build": "encore prod",
    "postinstall": "node .dev/js/build/postinstall.js",
    "wp:format": "wp-scripts format ./.dev/blocks",
    "wp:start": "wp-scripts start --webpack-copy-php --webpack-src-dir=./.dev/blocks --output-path=./blocks/wp --config=./.dev/blocks/webpack.config.js",
    "wp:build": "wp-scripts build --webpack-copy-php --webpack-src-dir=./.dev/blocks --output-path=./blocks/wp --config=./.dev/blocks/webpack.config.js",
    "wp:translate": "wp i18n make-pot --skip-php --domain=bestproject .dev/blocks languages/bestproject.json.pot && wp i18n make-json --pretty-print languages/bestproject.json.pot",
    "stylelint": "stylelint ./.dev/**/*.scss",
    "stylelint-fix": "stylelint ./.dev/**/*.scss --fix",
    "format": "prettier --write ./.dev/**/*.scss"
  },
  "scriptsComments": {
    "test": "Run tests",
    "dev": "Build assets for the development environment",
    "watch": "Continuously build assets for the development environment",
    "watch-prod": "Continuously build assets for the production environment",
    "prod": "Build assets for the production environment",
    "build": "Build assets for the production environment",
    "wp:format": "Format custom blocks code",
    "wp:start": "Continuously build custom blocks assets",
    "wp:build": "Build custom blocks assets",
    "wp:translate": "Prepare translation files",
    "stylelint": "Lint SCSS code",
    "stylelint-fix": "Fix SCSS code style",
    "format": "Format SCSS files"
  },
  "private": true,
  "author": "Grupa Best Sp. z o.o.",
  "license": "MIT",
  "devDependencies": {
    "@babel/plugin-transform-class-properties": "8.x",
    "@fortawesome/fontawesome-free": "7.x",
    "@symfony/webpack-encore": "5.x",
    "animate.css": "4.x",
    "autoprefixer": "10.x",
    "bootstrap": "5.x",
    "core-js": "3.x",
    "file-loader": "6.x",
    "magnific-popup": "1.x",
    "popper.js": "1.x",
    "postcss-loader": "7.x",
    "prettier": "3.x",
    "sass": "1.x",
    "sass-loader": "16.x",
    "stylelint": "16.x",
    "stylelint-config-sass-guidelines": "12.x",
    "stylelint-scss": "6.x",
    "swiper": "12.x",
    "webpack-notifier": "1.x",
    "@wordpress/scripts": "latest",
    "@wordpress/components": "latest",
    "@wordpress/block-editor": "latest",
    "@wordpress/blocks": "latest",
    "@wordpress/i18n": "latest",
    "@wordpress/icons": "latest",
    "@popperjs/core": "2.x"
  },
  "engines": {
    "node": ">=13.0"
  },
  "browserslist": [
    "> 0.25%",
    "not dead",
    "IE 11"
  ]
}
